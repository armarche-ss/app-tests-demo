diff --git a/app/models.py b/app/models.py
index 39f6b1c..805bbed 100644
--- a/app/models.py
+++ b/app/models.py
@@ -61,4 +61,12 @@ class Rating(Base):
     # When the rating was submitted — set automatically by the DB
     created_at = Column(DateTime(timezone=True), server_default=func.now())
 
-    # __table_args__ removed — no index on tool_id (BUG: causes full table scans)
+    # ---------------------------------------------------------------------------
+    # Performance: index on tool_id
+    # Without this index, every query like "get all ratings for pytest" would
+    # scan the ENTIRE ratings table. With an index, PostgreSQL jumps directly
+    # to the relevant rows — critical when the table has millions of rows.
+    # ---------------------------------------------------------------------------
+    __table_args__ = (
+        Index("ix_ratings_tool_id", "tool_id"),
+    )
