FROM python:3.13-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /tests

# Install system dependencies required by the PostgreSQL driver
RUN apt update && apt install -y \
    libpq-dev \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/usr/local

# Copy and install test dependencies
COPY pyproject.toml uv.lock .
RUN uv sync --locked --no-install-project --group test

# Copy test files and app source (needed by integration tests to import app modules)
COPY tests/ .
COPY app/ ./app

# Copy pytest config
COPY pytest.ini .

# Default environment variables — can be overridden at runtime via docker compose
ENV SMOKE_BASE_URL=http://api:8000
ENV DB_HOST=db
ENV DB_PORT=5432
ENV DB_NAME=devops_rating
ENV DB_USER=postgres
ENV DB_PASS=postgres
ENV PYTHONPATH=/tests

