# =============================================================================
# Dockerfile.tests — Container for running non-unit tests
#
# UNIT TESTS run locally on the developer's machine (no Docker needed).
# They use mocks and SQLite — no running services required.
#   → pytest tests/unit/
#
# ALL OTHER TESTS run inside this container because they need to reach
# real services (the api and db containers) over the Docker network:
#
#   Integration tests → need api:8000 (real FastAPI) + db:5432 (PostgreSQL)
#   Smoke tests       → need api:8000 to be live and healthy
#   Performance tests → Locust connects to api:8000 and simulates load
#
# This container shares the same Docker network as the app services,
# so it can resolve hostnames like "api" and "db" directly.
# =============================================================================

FROM python:3.11-slim

WORKDIR /tests

# Install system dependencies required by the PostgreSQL driver
RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy and install test dependencies
COPY requirements*.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

# Copy test files and app source (needed by integration tests to import app modules)
COPY tests/ ./tests/
COPY app/   ./app/

# Copy pytest config
COPY pytest.ini .

# Default environment variables — can be overridden at runtime via docker compose
ENV SMOKE_BASE_URL=http://api:8000
ENV DB_HOST=db
ENV DB_PORT=5432
ENV DB_NAME=devops_rating
ENV DB_USER=postgres
ENV DB_PASS=postgres
ENV PYTHONPATH=/tests

# Default command runs integration + smoke tests.
# Override at runtime:
#   docker compose run tests pytest tests/integration/ -v
#   docker compose run tests pytest tests/smoke/ -v
#   docker compose run tests locust -f tests/performance/locustfile.py --headless ...
CMD ["pytest", "tests/integration/", "tests/smoke/", "-v", "--tb=short"]
